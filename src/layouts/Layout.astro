---
import '../../design-system/tokens.css';
import '../styles/app.css';
import { SITE, SEO, STR, type Lang } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const seo = SEO[lang];
const t = STR[lang];

const frUrl = `${SITE.origin}${SITE.base}/`;
const enUrl = `${SITE.origin}${SITE.base}/en`;
const canonical = lang === 'fr' ? frUrl : enUrl;
const ogImage = `${SITE.origin}${SITE.ogImage}`;
const favicon = `${SITE.base}/favicon.svg`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B0D12" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Noah — Portfolio" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a href="#approach" class="visually-hidden">{t.skip}</a>
    <div class="field bg-grid" aria-hidden="true"></div>
    <div class="vignette" aria-hidden="true"></div>
    <div class="progress" aria-hidden="true"></div>
    <slot />
  </body>
</html>
